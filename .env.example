# Copy to .env for local dev, or set in Vercel → Project → Settings → Environment Variables.
# VITE_* values are embedded in the client bundle at build time (safe for publishable keys only).

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# Optional: server-only (do NOT prefix with VITE_)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_PUBLISHABLE_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
